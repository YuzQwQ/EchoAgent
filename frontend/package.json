{
  "name": "echo-desktop",
  "version": "0.2.0",
  "main": "main.js",
  "scripts": {
    "start": "npm run start:desktop",
    "start:desktop": "set ELECTRON_RUN_AS_NODE=& electron .",
    "start:launcher": "set ELECTRON_RUN_AS_NODE=& electron main_launcher.js",
    "start:bridge": "set ELECTRON_RUN_AS_NODE=& electron main_bridge.js",
    "dist": "npm run dist:desktop",
    "dist:desktop": "electron-builder",
    "dist:launcher": "electron-builder --config electron-builder.launcher.json",
    "dist:bridge": "electron-builder --config electron-builder.bridge.json"
  },
  "build": {
    "appId": "com.echo.desktop",
    "productName": "Echo Desktop",
    "win": {
      "target": "nsis",
      "verifyUpdateCodeSignature": false
    },
    "directories": {
      "output": "dist"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "Echo AI Desktop Client",
  "devDependencies": {
    "electron": "^39.2.7",
    "electron-builder": "^26.4.0"
  }
}
